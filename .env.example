# Telegram bot
BOT_TOKEN=
AUTHORIZED_USER_ID=
ALLOWED_CHAT_ID=

# General
TZ=Europe/Warsaw
# Host folder mounted into containers at DOWNLOADS_PATH.
DOWNLOADS_HOST_PATH=./downloads
DOWNLOADS_PATH=/downloads
PLEX_SERVICE_NAME=plexmediaserver
PUID=1000
PGID=1000

# qBittorrent
QB_URL=http://vpn:8080
QB_USER=
QB_PASS=
QB_WEBUI_PORT=8080
QB_TORRENT_PORT=6881
# URL used by qBittorrent completion hooks from inside the qBittorrent container.
QB_AUTORUN_QB_URL=http://127.0.0.1:8080
QB_CATEGORY_MOVIE_PATH=/downloads/Movie
QB_CATEGORY_TV_PATH=/downloads/TV
QB_CATEGORY_OTHERS_PATH=/downloads/Others

# Prowlarr, preferred for the new version
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=
# Torznab path segment used as: ${PROWLARR_URL}/${PROWLARR_DEFAULT_INDEXER}/api
PROWLARR_DEFAULT_INDEXER=all
PROWLARR_PORT=9696

# Jackett, optional legacy compatibility
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=
JACKETT_DEFAULT_INDEXER=all
JACKETT_PORT=9117
# Optional temporary migration fallback for old JSON config.
JACKETT_CONFIG_PATH=config.sample.json

# qBittorrent post-download hook options
NOTIFY_CHAT_ID=
QBT_DELETE_DELAY=15

# VPN placeholders for qmcgaw/gluetun. Exact values depend on provider/protocol.
# Proton speed note: WireGuard usually performs better than OpenVPN.
VPN_PROVIDER=
VPN_TYPE=openvpn
VPN_USERNAME=
VPN_PASSWORD=
VPN_WIREGUARD_PRIVATE_KEY=
VPN_WIREGUARD_ADDRESSES=
VPN_WIREGUARD_MTU=
VPN_SERVER_COUNTRIES=
VPN_FIREWALL_OUTBOUND_SUBNETS=
# Proton/qBittorrent port forwarding. Enable NAT-PMP when generating the Proton
# WireGuard config, then enable these and recreate the vpn/qbittorrent services.
VPN_PORT_FORWARDING=off
VPN_PORT_FORWARDING_PROVIDER=
VPN_PORT_FORWARDING_STATUS_FILE=/tmp/gluetun/forwarded_port
# Optional: sync Gluetun's forwarded port into qBittorrent. Requires qBittorrent
# Web UI to bypass authentication for localhost.
VPN_PORT_FORWARDING_UP_COMMAND=

# Watchtower
WATCHTOWER_CLEANUP=true
WATCHTOWER_POLL_INTERVAL=86400
